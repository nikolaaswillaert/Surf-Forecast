# WAHA (self-hosted WhatsApp API) settings
WAHA_BASE_URL=http://localhost:3000
WAHA_SESSION=default

# The WhatsApp chat ID that receives daily birthday reminders
# Format for a personal number: 1234567890@c.us  (country code + number, no +)
# Format for a group:           XXXXXXXXXX-XXXXXXXXXX@g.us
REMINDER_CHAT_ID=1234567890@c.us

# The surf forecast group — anyone typing "surf" here gets a surf report
SURF_GROUP_CHAT_ID=120363408937235805@g.us

# Flask webhook server settings
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5000

# Time to send daily reminders (24-hour HH:MM, server local time)
REMINDER_TIME=09:00
